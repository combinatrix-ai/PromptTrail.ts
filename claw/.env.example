DISCORD_TOKEN=

# Comma-separated channel names or ids where the bot may respond.
DISCORD_ALLOWED_CHANNELS=general

# false: respond in allowed channels without mention.
# true: require mention unless a channel is listed in DISCORD_FREE_RESPONSE_CHANNELS.
DISCORD_REQUIRE_MENTION=false
DISCORD_FREE_RESPONSE_CHANNELS=general
DISCORD_THREAD_REQUIRE_MENTION=false

# echo is useful for checking Discord registration/token/intents first.
# openai uses ai-sdk and requires OPENAI_API_KEY plus CLAW_OPENAI_MODEL.
# codex uses Codex App Server and requires CODEX_APP_SERVER_URL if not on the
# default ws://127.0.0.1:8390.
CLAW_REPLY_MODE=echo
CLAW_OPENAI_MODEL=

CODEX_APP_SERVER_URL=ws://127.0.0.1:8390
CLAW_CODEX_MODEL=
CLAW_CODEX_CWD=
CLAW_CODEX_TIMEOUT_MS=300000
